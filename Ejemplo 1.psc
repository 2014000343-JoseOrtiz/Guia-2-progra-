Algoritmo Dias_de_la_semana
	//Variable
	Definir dia Como Entero
	//Solicitar al usuario
	Escribir Sin Saltar 'Dame un numero netero del 1 al 7: '
	leer dia
	Segun dia Hacer
		1:
			Escribir 'lunes'
		2:
			Escribir 'martes'
		3:
			Escribir 'miercoles'
		4:
			Escribir 'jueves'
		5:
			Escribir 'viernes'
			
        6:
			Escribir 'Sabado'
		7:
			Escribir 'Domingo'
		De Otro Modo:
			Escribir 'Digite un valor entre 1 y el 7'
	Fin Segun
FinAlgoritmo
