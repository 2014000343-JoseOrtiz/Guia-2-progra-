Algoritmo Notas
	Definir n Como Entero
	//Solicitar al usuario
	Escribir Sin Saltar 'Dame una letra de A B C D F: '
	leer dia
	Segun dia Hacer
		"A":
			Escribir 'Exelente '
		"B":
			Escribir 'Bueno '
		"C":
			Escribir 'Regular'
		"D":
			Escribir 'Deficiente'
		"F":
			Escribir 'Reprobado'
			
		De Otro Modo:
			Escribir 'Digite un letra de A asta F'
	Fin Segun
FinAlgoritmo
	
